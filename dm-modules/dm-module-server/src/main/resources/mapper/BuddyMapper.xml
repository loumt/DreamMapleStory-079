<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.ms.dm.server.database.mapper.BuddyMapper">
    <resultMap type="cn.ms.dm.domain.buddy.vo.BuddyVO" id="detailMap">
        <result property="characterId" column="character_id"/>
        <result property="buddyId" column="buddy_id"/>
        <result property="name" column="name"/>
        <result property="level" column="level"/>
        <result property="job" column="job"/>
    </resultMap>

    <select id="listDetail" resultMap="detailMap">
        select b.character_id, b.buddy_id, c.name, c.`level`, c.job from dm_buddy b INNER JOIN dm_characters c ON b.character_id = c.id
    </select>

</mapper>
